# The canonical origin. Set this once a real domain exists — it is the only
# value that survives a custom domain, and it drives canonical URLs, the
# sitemap, robots.txt and the absolute OG image URL.
#
# On Vercel, leave it unset and the platform's own VERCEL_PROJECT_PRODUCTION_URL
# is used instead. Locally, an unset value falls back to http://localhost:3000,
# which is why a local build stamps localhost into the OG image footer.
NEXT_PUBLIC_SITE_URL=https://halfstep.vercel.app
